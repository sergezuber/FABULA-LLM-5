# FABULA-LLM-5 — environment template. Copy to `.env` and fill in. `.env` is gitignored.
# All variables are OPTIONAL unless noted; defaults are chosen for a local-first, single-machine setup.

# ── Cloud provider (optional) ────────────────────────────────────────────────
# Referenced by the engine config (fabula.config.json) as {env:NVIDIA_API_KEY}. Only needed
# if you enable the cloud provider and/or the local→cloud router below.
NVIDIA_API_KEY=

# ── Workflow graph + local→cloud router (plugin: fabula-graph) ───────────────
# Router is OFF by default (local-only). Set to 1 to let "heavy" steps escalate
# to the configured cloud model.
FABULA_ROUTER=0
# A step is "heavy" if it is web/research role or its brief exceeds this many chars.
FABULA_ROUTER_HEAVY_CHARS=400
# Per-call timeout for graph model calls (ms). Raise for slow local reasoning models.
FABULA_GRAPH_TIMEOUT_MS=240000
# Endpoint/model the graph uses for planning + local steps (defaults to the :1235 adapter).
FABULA_GRAPH_URL=http://localhost:1235/v1
FABULA_GRAPH_MODEL=

# ── Finding-your-unknowns + correctness gates (plugins: fabula-unknowns,
#    fabula-interview, fabula-reproduce-gate, fabula-change-quiz) ───────────────
# These close the gap between the ask and the codebase and gate a change on tests + comprehension.
# All steers/gates are ON by default; set one to 0 to SILENCE that specific self-firing steer (its
# tools stay available). Disable a whole plugin via the plugin manager or e.g. FABULA_DISABLE=unknowns.
# Reference-first steer (fires on the first source edit made without a reference/unknowns pass):
FABULA_REFERENCE_FIRST=1
# Interview auto-nudge (fires when a new task reads as underspecified):
FABULA_INTERVIEW_NUDGE=1
# Reproduce-first gate (validates the reproduction test against the pre-patch tree — a test that passes
# with AND without the change is fake, a fix that breaks a sibling is a regression, a validated test is
# frozen; degrades honestly to a not-validated marker when it cannot run, never trapping a correct fix):
FABULA_REPRODUCE_GATE=1
# Set =1 when the project's verify command only runs inside a container (a bench harness): the gate then
# skips the host-side fail-to-pass probe and marks the verdict `not-validated (docker-only)`.
FABULA_VERIFY_DOCKER_ONLY=
# Change-quiz gate (requires passing change_quiz — a comprehension check on your diff — before done):
FABULA_CHANGE_QUIZ=1
# Universal verification gate (plugin: fabula-attest) — verifies the deliverable of a NON-code task
# (analysis/plan/summary) by grounding each written claim against its cited source; silent on chat turns.
# EXPERIMENTAL: the plugin is default-OFF (enable via the plugin manager) until benchmarked; this switch
# additionally disables the gate when set to 0. Budget caps the per-turn entailment (aux-model) calls.
FABULA_ATTEST=1
FABULA_ATTEST_CALL_BUDGET=6
# Learn nudge (after a green verify of a real multi-step change, points at /distill to package it as a
# reusable skill — the light, manual alternative to the guarded auto-distill pass):
FABULA_LEARN_NUDGE=1
# Context-budget guard (plugin: fabula-ctxguard). Keeps one turn from outgrowing the socket's window: a
# "read all chapters / every file" task loads the whole corpus into one context and, past the device's
# memory budget, the model server crashes mid-answer. Near the window it makes the agent consolidate and
# shed raw text; on a bulk-read ask it steers to bounded batches. Inert below the high-water mark, so
# ordinary turns pay nothing. Set =0 to disable.
FABULA_CTX_GUARD=1
# The serving window in tokens (shared with the adapter's overflow telemetry) — the guard's ceiling.
# Keep it equal to the context length the model is actually LOADED with in LM Studio (default 131072).
FABULA_CONTEXT_WINDOW=131072
# Fraction of the window at which the guard forces consolidation (default 0.75 — leaves room for the reply).
FABULA_CTX_HIGH_WATER=0.75

# ── Subagent role preambles (plugin: fabula-reliability) ─────────────────────
# OFF by default; set to 1 to prepend terse role/STOP preambles to actor subagents.
FABULA_SOULS=0

# ── Push notifications via ntfy (plugin: fabula-reliability / fabula-ops) ─────
# Leave topic empty to disable. Set a topic and subscribe in the ntfy app to get
# pings on run finished / errored / loop-guard blocks / scheduled-job results.
FABULA_NTFY_TOPIC=
FABULA_NTFY_URL=https://ntfy.sh
FABULA_NTFY_ON_IDLE=1

# ── Mixture-of-agents extra endpoints (optional, plugin: fabula-tools) ────────
# JSON array of additional OpenAI-compatible endpoints, e.g.
# [{"name":"my-cloud","url":"https://.../v1/chat/completions","model":"...","key":"...","cloud":true}]
FABULA_MOA_ENDPOINTS=

# ── Vision / aux model fallback (optional) ───────────────────────────────────
FABULA_VISION_URL=
FABULA_VISION_KEY=
FABULA_VISION_MODEL=

# ── Local tooling paths (optional; auto-detected when on PATH) ────────────────
# Sandboxed code execution: "docker" (default if available) or "none".
FABULA_CODE_SANDBOX=
# Text-to-speech (piper) / speech-to-text (faster-whisper) integration.
FABULA_PIPER_BIN=
FABULA_PIPER_VOICE=
FABULA_WHISPER_PYTHON=

# ── Permission mode (optional; plugin: fabula-security) ──────────────────────
# default = normal guards; plan = read-only planning (writes blocked); acceptEdits =
# file edits pre-approved; bypass = skip FABULA guards (explicit opt-in, still logged).
# The in-chat tool set_permission_mode persists this across restarts (overrides the env).
FABULA_PERMISSION_MODE=

# ── Read-only agent contract (optional; plugin: fabula-security) ─────────────
# Set FABULA_READONLY=1 to run the whole session look-but-don't-touch (writes blocked).
# The built-in `explore` agent is always read-only; add more agent names (comma-separated)
# that should be read-only via FABULA_READONLY_AGENTS.
FABULA_READONLY=
FABULA_READONLY_AGENTS=

# ── Reasoning level (optional; plugin: the :1235 adapter) ────────────────────
# Default reasoning level applied to model requests when neither the X-Fabula-Reasoning
# header nor body.extra_body.fabula_reasoning is set. Levels are defined per-model in
# proxy/reasoning-map.json (e.g. enabled / off / strip / high). Empty = leave requests as-is.
FABULA_REASONING_LEVEL=

# ── Adapter stall watchdog (optional; the :1235 adapter) ─────────────────────
# A streaming read that goes silent this many seconds is aborted instead of wedging the
# turn for minutes (local reasoning models can stall / spiral emitting zero tokens). Set
# generously above worst-case prefill-to-first-token, far below any minutes-long hang.
FABULA_STREAM_IDLE_TIMEOUT=120
# Retry the whole request once if it stalls before the first byte (safe: nothing forwarded yet).
FABULA_STREAM_RETRIES=1
# Socket timeout for non-streaming (structured/judge) calls.
FABULA_UPSTREAM_TIMEOUT=900

# ── Adapter admission control + measured idle budget (optional; the :1235 adapter) ──
# NB the adapter reads THIS FILE at startup (its LaunchAgent passes no environment of its own), so a knob
# set here really does reach the running adapter. A real environment variable still takes precedence.
# This serving class (quantized MoE on consumer hardware) matches cloud latency at low
# concurrency and collapses under concurrent prefill. Every session, background pass and
# witness call funnels through the one adapter, so it is the only place that can serialize
# them. 0 = UNLIMITED (today's behaviour); 1 = one upstream request at a time, the rest queue.
FABULA_MAX_CONCURRENT_UPSTREAM=1
# How long a queued request may wait before the gate FAILS OPEN and lets it through anyway.
# A streaming caller is kept alive with SSE keepalives while it waits; a non-streaming caller
# (judge, embeddings, /v1/models) receives nothing, so keep this short enough that it survives.
FABULA_ADMIT_WAIT_MAX=60
# The inter-token idle budget is measured per (model, prompt-size bucket) instead of being one
# flat number. Cold start returns FABULA_STREAM_IDLE_TIMEOUT unchanged. 0 disables the
# measurement and restores the flat constant everywhere.
FABULA_IDLE_BASELINE=1
# Upper clamp on that measured budget.
FABULA_IDLE_CEILING=600
# Lower clamp (floor) on that measured budget — the pause the watchdog ALWAYS tolerates between tokens,
# even after fast evidence. Critical for reasoning models: they emit a reasoning block, then go silent
# for many seconds while planning the next step / first answer token — a legitimate pause the byte-level
# watchdog cannot distinguish from a hang. Too low (the 30s code default) and that pause is cut mid-turn
# (finish=other → a truncated reasoning-only step that then looks like a think-only stall), and the pause
# is never recorded so the measured budget can never grow to cover it. Raise it for heavy-context (100K+)
# reasoning models so the first real pause survives and gets measured. Default 30 keeps prior behavior.
FABULA_IDLE_FLOOR=120
# Telemetry only: classify WHY a prefix cache broke (position-shift vs content-break) and name
# the volatile block that shifted stable content. 0 restores the pre-existing CACHE-BREAK line.
FABULA_CACHE_BREAK_CLASS=1
# >0: clamp every request's max_tokens to this ceiling (hard cap on runaway generation). 0 = off.
FABULA_MAX_OUTPUT_TOKENS=0

# ── Output / safety knobs (optional) ─────────────────────────────────────────
# Cap on a single tool's output size before truncation (chars).
FABULA_TOOL_OUTPUT_CAP=
# Directory for user-defined skills.
FABULA_SKILLS_DIR=

# ── Plugins (declared in plugin/lib/manifest.ts; managed in-app via list_plugins/enable_plugin/…) ───
# Disable plugins without the UI: comma-separated ids, e.g. browser,ops. On/off state otherwise lives in
# ~/.config/mimocode/fabula-state.json (the engine's config dir, outside the repo).
FABULA_DISABLE=
# Override the on/off state file path (tests / non-standard installs).
FABULA_PLUGIN_STATE=
# text_to_speech voice for the built-in macOS `say` fallback (default: picked by text language, else system voice).
FABULA_SAY_VOICE=

# ── App runtime resolution (optional; set only for non-standard layouts) ─────
# Repo checkout the app should use (default: auto — FABULA_HOME → the .app's parent dir → ~/FABULA-LLM-5).
FABULA_HOME=
# Engine binary for the app (default: `fabula` from PATH, falling back to the raw engine CLI).
FABULA_ENGINE=
# Engine binary for scheduled jobs (default: auto-detected fabula shim, then the raw engine CLI).
FABULA_ENGINE_BIN=
# Script that starts your local SearXNG instance (optional; empty = don't auto-start).
FABULA_SEARXNG_START=

# ── Coding tool belt (optional; plugin: fabula-context) ──
# Set to "coding" to mask non-coding tool schemas from the model each turn (browser/vision/ops/weather/
# places/multimodal) — cuts prefill (measured: 125 -> 101 tool schemas). Empty = all tools visible.
FABULA_PROFILE=

# ── Context OS ──
# Per-task tool router (plugin: fabula-toolrouter, toggle id "tool-router" — enable BOTH): on every
# real user message the task is deterministically classified into a closed profile (coding /
# web-research / full) and only that profile's tool schemas reach the model, per SESSION (parallel
# chats never clash; the static FABULA_TOOL_MASK stays as a floor). Gate tools are never masked; a
# masked tool called by name still executes via shadow dispatch. Gate PASSED on the real-model
# A/B bench (success 7/7 vs 6/7 off; prefill −2.3k/step; cache-breaks −23%) → the APP sets =1 by
# default; empty here = off for bare CLI runs. Kill-switch: unset / disable the plugin toggle.
FABULA_TOOL_ROUTER=
# Per-source schema-token breakdown on the engine's fabula-belt log line (Phase-0 audit). Default: off.
FABULA_CONTEXT_AUDIT=
# Adapter audit tap: write the LAST /chat/completions request body (post-transform) to this file for
# offline per-layer analysis (proxy/context_audit.py analyze <file>). Default: off (empty).
FABULA_DUMP_LAST_REQUEST=

# ── Auto-goal (the mission default: never end the turn until the work is done) ──
# Every real user task on the main agent automatically arms the same stop-condition gate /goal
# uses: before honoring a stop, an independent judge reads the transcript and refuses the stop
# until the request is genuinely fulfilled. Explicit /goal conditions are never clobbered; a
# previous auto goal is replaced by the next task (latest task wins). Judge is fail-open — a
# broken judge can never trap the user. The APP sets =1 by default; empty here = off for bare
# CLI runs and tests. Kill-switch: FABULA_AUTO_GOAL=0 in ~/.fabula/.env.
FABULA_AUTO_GOAL=
# Re-entry cap for AUTO-armed goals (explicit /goal keeps its own cap of 12). Default: 3.
FABULA_AUTO_GOAL_MAX=
# Goal-gate "answer is terminal" stop-layer (default ON). An AUTO goal is honored (stop, no judge
# call) when the turn produced no verifiable artifact — a pure conversational / Q&A answer is a
# terminal ANSWER and must not re-enter the judge loop. Arming is likewise skipped in a project with
# no verify command. This keeps the gate for real verifiable work while never looping on chat turns
# (model-agnostic: any model in the socket). Explicit /goal is untouched — it always reaches the
# judge (bounded by its cap of 12). Kill-switch: FABULA_GOAL_VERIFY_GATE=0.
FABULA_GOAL_VERIFY_GATE=
# Judge hard-veto (default ON). The judge is ONE call on the SAME model in the socket — the worst
# calibration setting, so an overconfident "done" can end a turn whose DYNAMICS say otherwise. Before a
# stop is honored the harness consults the trajectory it measured itself (verify greens/reds and the last
# outcome, auto-rewinds, a stamped terminal NOT-DONE, unverified source edits) and REFUSES the stop on a
# self-evident not-done signal — falling into the SAME bounded re-entry path (never a new loop: the
# re-entry cap still ends the turn, and a later green verify clears the veto). The judge also receives the
# measured trajectory so its own verdict is grounded. Kill-switch: FABULA_JUDGE_HARD_VETO=0.
FABULA_JUDGE_HARD_VETO=

# ── Receipt model identity (context provenance v0.2) ──
# Registry API the receipt reads the serving model's descriptor from (id/arch/quantization/publisher).
# The descriptor hash pins WHICH build/quant served the run — it is NOT a weights hash and the receipt
# says so. Default: LM Studio's native registry.
FABULA_MODEL_API=
# Set =1 to also stamp a REAL weights digest: sha256 over the model's weight files on disk (first
# hash of a big model takes a while; cached by size+mtime, so later mints are instant). The field
# appears ONLY when files were actually hashed — it is never synthesized from metadata.
FABULA_WEIGHTS_DIGEST=
# Explicit model directory for the weights digest (else auto-located under ~/.lmstudio/models).
FABULA_MODEL_DIR=

# ── Disrupt layer (experimental plugins, all OFF by default — enable in Settings ▸ Plugins) ──
# Witness: an independent model of a DIFFERENT family adversarially reviews the diff.
FABULA_WITNESS_MODEL=
FABULA_WITNESS_URL=
FABULA_WITNESS_API_KEY=
# Relay: budget caps for the cloud-writes-the-patch escalation loop (patch is never trusted).
FABULA_RELAY_URL=
FABULA_RELAY_MODEL=
FABULA_RELAY_MAX_ATTEMPTS=
# Registry: optional remote for publishing content-addressed proof receipts.
FABULA_REGISTRY_REMOTE=
# Daemon (KAIROS background posture) + terminal-focus signal it reads.
FABULA_DAEMON=
FABULA_TERMINAL_FOCUS=
# Buddy: set =0 to stop auto-feeding the pet from green receipts.
FABULA_BUDDY_AUTO=
# Escalate: preferred cloud model/provider for the second-opinion tool.
FABULA_ESCALATE_MODEL=
FABULA_ESCALATE_PROVIDER=

# ── Escalation economics (W6; plugins + the :1235 adapter) ──
# The harness decides when to ask a stronger model for a second opinion, from measured evidence (how
# many verifications failed in a row, whether attempts keep churning the same file, how much wall-clock
# the streak has burned) instead of a bare counter. 0 restores the pre-W6 fixed thresholds.
FABULA_RISK_SCORE=1
# The harness FIRES that escalation itself rather than asking the model to. 0 goes back to the prose
# steer, which the model was free to ignore.
FABULA_ESCALATE_AUTO=1
# How many second opinions ONE task may buy (escalation spends against a paid endpoint).
FABULA_ESCALATE_MAX=2
# How long the harness waits for one. Short on purpose: the agent is blocked while it waits, so a slow
# or hung cloud must cost seconds and then be forgotten.
FABULA_ESCALATE_TIMEOUT_MS=8000
# Where the escalation-decision ledger lives (used to score WHEN the harness asks for help — Ask-F1).
# Defaults to <XDG_DATA_HOME>/fabula/ask-ledger.json.
# FABULA_ASK_LEDGER_FILE=

# How long a queued caller may wait before the gate lets it through anyway. A STREAMING caller receives
# keepalives while it waits and can survive a long one; a SILENT caller (judge, embeddings) cannot tell
# waiting from a hang, so its ceiling stays short.
FABULA_ADMIT_WAIT_MAX_STREAM=300
# How many sessions the router's per-session channels keep resident. They live for the life of the
# server process and the shadow one holds tool closures, so they are capped rather than unbounded.
FABULA_CHANNEL_MAX_SESSIONS=32
# The quality estimate that can promote "keep trying locally" to "ask a stronger model now". It can
# never do the reverse and never gates a verify. 0 disables it.
FABULA_QE=1

# ── Anchored memory (W7; plugin fabula-memory, default OFF) ──
# A memory is bound at write time to the code it is about and re-checked before it is served. What to do
# when the anchor no longer resolves: `withhold` (say nothing) or `evidence` (serve the CURRENT source in
# its place). There is deliberately no "serve it with a stale label" option — a hedge beside a memory is
# measured to make the decision worse, not safer.
FABULA_MEM_STALE_MODE=withhold
# Keep hard constraints verbatim past the context budget instead of cutting the file positionally.
# 0 restores the pre-W7 behaviour byte-for-byte.
FABULA_MEM_PIN=1
# Count whether a memory co-occurred with success or failure, so usefulness can be ranked from evidence.
FABULA_MEM_WORTH=1
# Promotion decisions start in SHADOW: journalled to promotion_decisions.jsonl, acting on nothing.
# Set to 1 once you have read the journal and want the decisions to take effect.
FABULA_MEM_PROMOTE=0
# Where the memory store lives. Defaults to <XDG_DATA_HOME>/fabula/memstore.
# FABULA_MEM_STORE=

# ── Claim re-checking (W8; the receipt and its verification) ──
# A receipt asserts more than one kind of thing. That the code passes its tests is EXPENSIVE to forge and
# was always re-run. Which model, which weights, which context is CHEAP to forge and used to be printed
# straight back out of the receipt being checked. With this on, every identity claim lands in exactly one
# state and says which: re-verified here, not checkable here, or a mismatch. 0 restores the pre-W8 output
# byte-for-byte on every surface (minted receipt, verify_receipt, the CLI).
FABULA_RECHECK=1
# The identity re-computation specifically. Off means every identity claim reports as not-checkable —
# which is the honest description of what the pre-W8 code did, having simply echoed the receipt's numbers.
FABULA_RECHECK_IDENTITY=1
# Re-hashing the weight files costs minutes on a real model, so it is opt-in and never default. When it is
# off, the receipt says so BY NAME rather than staying silent: silence is indistinguishable from a field
# that was checked.
# FABULA_WEIGHTS_DIGEST=1

# Decision-trace flight recorder (engine): JSONL of every harness decision (gates, loop breaks, overflow
# routing, checkpoint thresholds, writer settles, summarizer verdicts) to ~/.local/share/fabula/log/trace.jsonl.
# Invisible to the user; for debugging stalls/loops. Live toggle WITHOUT restart: `touch ~/.local/share/fabula/trace.on`
# (remove the file to stop). This env var overrides the marker in BOTH directions; leave unset normally.
FABULA_TRACE=
