# FABULA-LLM-5 — environment template. Copy to `.env` and fill in. `.env` is gitignored.
# All variables are OPTIONAL unless noted; defaults are chosen for a local-first, single-machine setup.

# ── Cloud provider (optional) ────────────────────────────────────────────────
# Referenced by the engine config (fabula.config.json) as {env:NVIDIA_API_KEY}. Only needed
# if you enable the cloud provider and/or the local→cloud router below.
NVIDIA_API_KEY=

# ── Workflow graph + local→cloud router (plugin: fabula-graph) ───────────────
# Router is OFF by default (local-only). Set to 1 to let "heavy" steps escalate
# to the configured cloud model.
FABULA_ROUTER=0
# A step is "heavy" if it is web/research role or its brief exceeds this many chars.
FABULA_ROUTER_HEAVY_CHARS=400
# Per-call timeout for graph model calls (ms). Raise for slow local reasoning models.
FABULA_GRAPH_TIMEOUT_MS=240000
# Endpoint/model the graph uses for planning + local steps (defaults to the :1235 adapter).
FABULA_GRAPH_URL=http://localhost:1235/v1
FABULA_GRAPH_MODEL=

# ── Finding-your-unknowns + correctness gates (plugins: fabula-unknowns,
#    fabula-interview, fabula-reproduce-gate, fabula-change-quiz) ───────────────
# These close the gap between the ask and the codebase and gate a change on tests + comprehension.
# All steers/gates are ON by default; set one to 0 to SILENCE that specific self-firing steer (its
# tools stay available). Disable a whole plugin via the plugin manager or e.g. FABULA_DISABLE=unknowns.
# Reference-first steer (fires on the first source edit made without a reference/unknowns pass):
FABULA_REFERENCE_FIRST=1
# Interview auto-nudge (fires when a new task reads as underspecified):
FABULA_INTERVIEW_NUDGE=1
# Reproduce-first gate (downgrades a green verify_done when source changed but no test was added):
FABULA_REPRODUCE_GATE=1
# Change-quiz gate (requires passing change_quiz — a comprehension check on your diff — before done):
FABULA_CHANGE_QUIZ=1
# Learn nudge (after a green verify of a real multi-step change, points at /distill to package it as a
# reusable skill — the light, manual alternative to the guarded auto-distill pass):
FABULA_LEARN_NUDGE=1

# ── Subagent role preambles (plugin: fabula-reliability) ─────────────────────
# OFF by default; set to 1 to prepend terse role/STOP preambles to actor subagents.
FABULA_SOULS=0

# ── Push notifications via ntfy (plugin: fabula-reliability / fabula-ops) ─────
# Leave topic empty to disable. Set a topic and subscribe in the ntfy app to get
# pings on run finished / errored / loop-guard blocks / scheduled-job results.
FABULA_NTFY_TOPIC=
FABULA_NTFY_URL=https://ntfy.sh
FABULA_NTFY_ON_IDLE=1

# ── Mixture-of-agents extra endpoints (optional, plugin: fabula-tools) ────────
# JSON array of additional OpenAI-compatible endpoints, e.g.
# [{"name":"my-cloud","url":"https://.../v1/chat/completions","model":"...","key":"...","cloud":true}]
FABULA_MOA_ENDPOINTS=

# ── Vision / aux model fallback (optional) ───────────────────────────────────
FABULA_VISION_URL=
FABULA_VISION_KEY=
FABULA_VISION_MODEL=

# ── Local tooling paths (optional; auto-detected when on PATH) ────────────────
# Sandboxed code execution: "docker" (default if available) or "none".
FABULA_CODE_SANDBOX=
# Text-to-speech (piper) / speech-to-text (faster-whisper) integration.
FABULA_PIPER_BIN=
FABULA_PIPER_VOICE=
FABULA_WHISPER_PYTHON=

# ── Permission mode (optional; plugin: fabula-security) ──────────────────────
# default = normal guards; plan = read-only planning (writes blocked); acceptEdits =
# file edits pre-approved; bypass = skip FABULA guards (explicit opt-in, still logged).
# The in-chat tool set_permission_mode persists this across restarts (overrides the env).
FABULA_PERMISSION_MODE=

# ── Read-only agent contract (optional; plugin: fabula-security) ─────────────
# Set FABULA_READONLY=1 to run the whole session look-but-don't-touch (writes blocked).
# The built-in `explore` agent is always read-only; add more agent names (comma-separated)
# that should be read-only via FABULA_READONLY_AGENTS.
FABULA_READONLY=
FABULA_READONLY_AGENTS=

# ── Reasoning level (optional; plugin: the :1235 adapter) ────────────────────
# Default reasoning level applied to model requests when neither the X-Fabula-Reasoning
# header nor body.extra_body.fabula_reasoning is set. Levels are defined per-model in
# proxy/reasoning-map.json (e.g. enabled / off / strip / high). Empty = leave requests as-is.
FABULA_REASONING_LEVEL=

# ── Adapter stall watchdog (optional; the :1235 adapter) ─────────────────────
# A streaming read that goes silent this many seconds is aborted instead of wedging the
# turn for minutes (local reasoning models can stall / spiral emitting zero tokens). Set
# generously above worst-case prefill-to-first-token, far below any minutes-long hang.
FABULA_STREAM_IDLE_TIMEOUT=120
# Retry the whole request once if it stalls before the first byte (safe: nothing forwarded yet).
FABULA_STREAM_RETRIES=1
# Socket timeout for non-streaming (structured/judge) calls.
FABULA_UPSTREAM_TIMEOUT=900
# >0: clamp every request's max_tokens to this ceiling (hard cap on runaway generation). 0 = off.
FABULA_MAX_OUTPUT_TOKENS=0

# ── Output / safety knobs (optional) ─────────────────────────────────────────
# Cap on a single tool's output size before truncation (chars).
FABULA_TOOL_OUTPUT_CAP=
# Directory for user-defined skills.
FABULA_SKILLS_DIR=

# ── Plugins (declared in plugin/lib/manifest.ts; managed in-app via list_plugins/enable_plugin/…) ───
# Disable plugins without the UI: comma-separated ids, e.g. browser,ops. On/off state otherwise lives in
# ~/.config/mimocode/fabula-state.json (the engine's config dir, outside the repo).
FABULA_DISABLE=
# Override the on/off state file path (tests / non-standard installs).
FABULA_PLUGIN_STATE=
# text_to_speech voice for the built-in macOS `say` fallback (default: picked by text language, else system voice).
FABULA_SAY_VOICE=

# ── App runtime resolution (optional; set only for non-standard layouts) ─────
# Repo checkout the app should use (default: auto — FABULA_HOME → the .app's parent dir → ~/FABULA-LLM-5).
FABULA_HOME=
# Engine binary for the app (default: `fabula` from PATH, falling back to the raw engine CLI).
FABULA_ENGINE=
# Engine binary for scheduled jobs (default: auto-detected fabula shim, then the raw engine CLI).
FABULA_ENGINE_BIN=
# Script that starts your local SearXNG instance (optional; empty = don't auto-start).
FABULA_SEARXNG_START=

# ── Coding tool belt (optional; plugin: fabula-context) ──
# Set to "coding" to mask non-coding tool schemas from the model each turn (browser/vision/ops/weather/
# places/multimodal) — cuts prefill (measured: 125 -> 101 tool schemas). Empty = all tools visible.
FABULA_PROFILE=

# ── Context OS ──
# Per-task tool router (plugin: fabula-toolrouter, toggle id "tool-router" — enable BOTH): on every
# real user message the task is deterministically classified into a closed profile (coding /
# web-research / full) and only that profile's tool schemas reach the model, per SESSION (parallel
# chats never clash; the static FABULA_TOOL_MASK stays as a floor). Gate tools are never masked; a
# masked tool called by name still executes via shadow dispatch. Gate PASSED on the real-model
# A/B bench (success 7/7 vs 6/7 off; prefill −2.3k/step; cache-breaks −23%) → the APP sets =1 by
# default; empty here = off for bare CLI runs. Kill-switch: unset / disable the plugin toggle.
FABULA_TOOL_ROUTER=
# Per-source schema-token breakdown on the engine's fabula-belt log line (Phase-0 audit). Default: off.
FABULA_CONTEXT_AUDIT=
# Adapter audit tap: write the LAST /chat/completions request body (post-transform) to this file for
# offline per-layer analysis (proxy/context_audit.py analyze <file>). Default: off (empty).
FABULA_DUMP_LAST_REQUEST=

# ── Auto-goal (the mission default: never end the turn until the work is done) ──
# Every real user task on the main agent automatically arms the same stop-condition gate /goal
# uses: before honoring a stop, an independent judge reads the transcript and refuses the stop
# until the request is genuinely fulfilled. Explicit /goal conditions are never clobbered; a
# previous auto goal is replaced by the next task (latest task wins). Judge is fail-open — a
# broken judge can never trap the user. The APP sets =1 by default; empty here = off for bare
# CLI runs and tests. Kill-switch: FABULA_AUTO_GOAL=0 in ~/.fabula/.env.
FABULA_AUTO_GOAL=
# Re-entry cap for AUTO-armed goals (explicit /goal keeps its own cap of 12). Default: 3.
FABULA_AUTO_GOAL_MAX=
# Goal-gate "answer is terminal" stop-layer (default ON). An AUTO goal is honored (stop, no judge
# call) when the turn produced no verifiable artifact — a pure conversational / Q&A answer is a
# terminal ANSWER and must not re-enter the judge loop. Arming is likewise skipped in a project with
# no verify command. This keeps the gate for real verifiable work while never looping on chat turns
# (model-agnostic: any model in the socket). Explicit /goal is untouched — it always reaches the
# judge (bounded by its cap of 12). Kill-switch: FABULA_GOAL_VERIFY_GATE=0.
FABULA_GOAL_VERIFY_GATE=
