# ── Secrets / keys (never commit) ─────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
*secret*
*credentials*

# ── OS / editor ───────────────────────────────────────────────
.DS_Store
*.swp

# ── Local tool state (regenerable) ────────────────────────────
.fabula/
.serena/
# …except the demo's published Proof-of-Done receipts (committed evidence, replayed verbatim)
!demo/.fabula/
demo/.fabula/*
!demo/.fabula/receipts/

# ── Dependencies (regenerable) ────────────────────────────────
node_modules/
**/node_modules/
.venv/
venv/
__pycache__/
*.pyc

# ── Build artifacts ───────────────────────────────────────────
*.app/
.build/
**/.build/
DerivedData/
dist/
build/

# ── Runtime logs / databases ──────────────────────────────────
*.log
*.db
*.sqlite

# ── Personal working config (start from the *.example templates) ──
/fabula.config.json
/fabula.config.jsonc

# ── Vendored engine build artifacts (regenerable) ─────────────
engine/**/dist/
engine/**/node_modules/
# Repo-local installed engine binary + any build backups (108MB each, regenerated by build.sh; the app runs this)
/bin/
engine/**/*.gen.ts
# EXCEPTION: commit the SDK's generated client. The frontend build imports it, but it is produced by a
# codegen step (bun dev generate + @hey-api/openapi-ts) that build.sh does NOT run before the frontend
# build — so a fresh clone without these files fails to build. Committing them makes `./setup.sh` build
# from a clean checkout with no codegen toolchain. Regenerate on engine-API changes: bun run build (in engine/packages/sdk/js).
!engine/packages/sdk/js/src/gen/**/*.gen.ts
!engine/packages/sdk/js/src/v2/gen/**/*.gen.ts
engine/.turbo/
engine/**/.turbo/

# ── Contributor guide kept local (not published) ──
/CLAUDE.md

# ── Private benchmark harness + results (NEVER commit — internal only) ──
private-bench/

# ── Private launch / marketing notes (internal only, never published) ──
/docs/LAUNCH-PLAYBOOK.md
